#include <stdio.h>
#include <ctype.h>

int main(){
    char ch;
    int lines=0, words=0, chars=0, inword=0;

    while((ch=getchar())!=EOF){
        chars++;
        if(ch=='\n') lines++;
        if(isspace(ch)) inword=0;
        else if(!inword){
            words++;
            inword=1;
        }
    }

    printf("Lines=%d Words=%d Characters=%d\n",lines,words,chars);
}

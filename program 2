#include <stdio.h>

int main(){
    char ch, prev = 0;

    while((ch = getchar()) != EOF){
        if(prev == '/' && ch == '/'){
            while((ch = getchar()) != '\n');
        }
        else if(prev == '/' && ch == '*'){
            while((ch = getchar())){
                if(prev == '*' && ch == '/') break;
                prev = ch;
            }
            prev = 0;
        }
        else{
            if(prev) putchar(prev);
            prev = ch;
        }
    }
}
